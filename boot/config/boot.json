{
    "title": "EMOS Bootloader",
    "password": null,
    "theme": "default",
    "timeout": 5,
    "default_entry": 0,
    "start_script": [
        "usefont boot:/unifont.bfn"
    ],
    "options": [
        {
            "name": "Boot from next device",
            "script": "bootnext"
        },
        {
            "name": "Boot from current device",
            "script": [
                "mount fd0pt0p2 sys",
                "vmode 640x480x32",
                "boot sys:/system/kernel/kernel.elf"
            ]
        },
        {   
            "name": "Start bootloader shell",
            "script": [
                "clear",
                "shell"
            ]
        }
    ]
}
